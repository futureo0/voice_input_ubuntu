# 火山引擎豆包/SeedASR 凭据，必须填写。
# App Key 和 Access Key 来自火山引擎控制台对应应用。
VOLC_ASR_APP_KEY=your_app_key
VOLC_ASR_ACCESS_KEY=your_access_key

# ASR 资源配置。
# VOLC_ASR_RESOURCE_ID 必须是当前应用已经开通/授权的资源 ID；
# 如果启动后看到 requested resource not granted，通常就是这里和控制台授权不匹配。
# 常见流式大模型资源 ID：
# - volc.bigasr.sauc.duration
# - volc.bigasr.sauc.concurrent
# - volc.seedasr.sauc.duration
# - volc.seedasr.sauc.concurrent
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# 默认接入地址适合当前脚本的“按一下开始、再按一下结束后返回最终文本”模式。
# 如果控制台或官方文档给了你不同的接入地址，可以改这里。
VOLC_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream

# 用户标识。一般不用改，只要在服务端请求里保持非空即可。
VOLC_ASR_UID=voice-input

# 音频采集配置。
# VOICE_INPUT_AUDIO_DEVICE 默认使用系统默认麦克风；如果要指定设备，可先用 arecord -L 查看。
# 采样率默认 16000，和当前 ASR 请求参数保持一致；不确定时不要改。
# CHUNK_MS 是每次发送给 ASR 的音频片段长度，越小延迟越低但请求更碎。
VOICE_INPUT_AUDIO_DEVICE=default
VOICE_INPUT_SAMPLE_RATE=16000
VOICE_INPUT_CHUNK_MS=200

# 识别结束后等待最终结果的秒数。网络慢或服务端返回慢时可以调大。
VOICE_INPUT_FINAL_TIMEOUT=12

# 调试开关。设为 1 会打印 ASR 响应细节，排查“No recognized text”时很有用。
VOICE_INPUT_DEBUG=0

# 桌面通知开关。设为 0 后不弹录音中、识别中、完成等系统通知。
VOICE_INPUT_NOTIFICATIONS=1

# 录音开始/结束音效开关。
# 设为 1 时，开始录音前播放一个短促的“开启”提示音，录音停止后播放一个“完成”提示音。
# 开始提示音会在 arecord 真正开始采集前播放，尽量避免把提示音录进语音内容。
# 设为 0 则完全静音，只保留终端输出和桌面通知。
VOICE_INPUT_SOUNDS=1

# 录音开始/结束音效音量，范围 0-200。
# 这是相对当前系统音效音量的倍率：0=静音，100=系统原始音量，200=两倍音量。
# 内部会把这个百分比换算成播放器需要的音量参数；不影响麦克风音量和系统主音量。
VOICE_INPUT_SOUND_VOLUME=100

# 长时间录音保护。
# 每录满 RECORDING_REMINDER_SECONDS 秒会播放一次提示音，音量为 VOICE_INPUT_SOUND_VOLUME 的 50%。
# SILENCE_TIMEOUT_SECONDS 秒内没有检测到语音活动时，会自动停止本次录音。
# VAD_AGGRESSIVENESS 仅在安装了 webrtcvad 时生效：0 最宽松，3 最严格。
# VAD_MIN_RMS 是无 webrtcvad 时的自适应能量 VAD 下限；容易误停可调低，底噪误触可调高。
VOICE_INPUT_RECORDING_REMINDER_SECONDS=60
VOICE_INPUT_SILENCE_TIMEOUT_SECONDS=20
VOICE_INPUT_VAD_AGGRESSIVENESS=2
VOICE_INPUT_VAD_MIN_RMS=160

# 麦克风自动修复。
# 启动录音前，如果默认麦克风静音或音量过低，脚本会自动解除静音并设置到目标音量。
VOICE_INPUT_MIC_AUTO_FIX=1
VOICE_INPUT_MIC_TARGET_VOLUME=30
VOICE_INPUT_MIC_MIN_VOLUME=10

# CopyQ 和自动粘贴。
# COPYQ_HISTORY=1 表示把识别文本写入 CopyQ 最新历史。
# AUTO_PASTE=1 表示识别完成后由 CopyQ 向当前焦点执行粘贴。
# PASTE_DELAY_MS 可在复制和粘贴之间加一点等待，某些应用焦点恢复慢时可以调大。
VOICE_INPUT_COPYQ_HISTORY=1
VOICE_INPUT_AUTO_PASTE=1
VOICE_INPUT_PASTE_DELAY_MS=0

# Alt 轻按触发的基础防抖时间，单位毫秒。
# 它用于避免一次按键释放被重复处理；Alt+Tab、Alt+F4 这类组合不会触发。
VOICE_INPUT_ALT_DEBOUNCE_MS=350

# M585/M590 鼠标滚轮左拨触发。
# WHEEL=1 表示启用 M585/M590 水平滚轮作为第二触发源。
# DEVICE_NAMES 用逗号分隔，只监听设备名包含这些片段的 evdev 设备。
VOICE_INPUT_M585_WHEEL=1
VOICE_INPUT_M585_DEVICE_NAMES=M585,M590

# 水平滚轮方向。
# 大多数设备左拨是 -1；如果你发现右拨触发、左拨不触发，把这里改成 1。
VOICE_INPUT_M585_LEFT_SIGN=-1

# 是否“截胡”左拨原始功能。
# 设为 1 时，脚本会尝试使用 /dev/uinput 创建虚拟输入设备：
# 独占真实 M585/M590 事件设备、转发移动/点击/普通滚轮等其他事件，只丢弃左拨水平滚轮。
# 如果 /dev/uinput 权限不足，脚本会自动退回被动监听；左拨仍能触发，但原来的水平滚动也会生效。
# 设为 0 则永远只被动监听，不尝试截胡。
VOICE_INPUT_M585_INTERCEPT=1

# M585/M590 左拨手势锁定时间，单位毫秒。
# M585 的一次左拨可能会连续吐出多个 REL_HWHEEL 事件；这个值用于把一串事件视为一次手势。
# 如果一次左拨仍然出现“开始 -> 停止 -> 又开始”，把它调大，例如 1600 或 2000。
# 如果你想快速连续拨动两次分别开始/停止，可以适当调小。
VOICE_INPUT_M585_GESTURE_MS=1200
